#. Plugin Name of the plugin
#: index.php
msgid "Real Cookie Banner"
msgstr "Real Cookie Banner"

#. Plugin URI of the plugin
#: index.php inc/view/Banner.php:270
msgid "https://devowl.io/wordpress-real-cookie-banner/"
msgstr "https://devowl.io/wordpress-real-cookie-banner/"

#. Description of the plugin
#: index.php
msgid ""
"Obtain GDPR (DSGVO) and ePrivacy (EU cookie law) compliant opt-in consent. "
"Find cookies and fill all legal information in your cookie banner. More than "
"just a cookie notice!"
msgstr ""
"Obtenga el consentimiento previo informado u opt-in de conformidad con el "
"Reglamento RGPD (Reglamento General de Protección de Datos) o GDPR por sus "
"siglas en inglés, y la Directiva ePrivacy (ley de la UE sobre cookies). "
"Encuentre cookies y rellene toda la información legal en su banner. ¡Somos "
"mucho más que un aviso de cookies!"

#. Author of the plugin
#: index.php
msgid "devowl.io"
msgstr "devowl.io"

