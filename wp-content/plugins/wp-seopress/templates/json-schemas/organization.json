{
    "@context": "https://schema.org",
    "@type": "[[type]]",
    "name": "[[name]]",
    "legalName": "[[legal_name]]",
    "url": "[[url]]",
    "alternateName": "[[alternate_name]]",
    "description": "[[description]]",
    "logo": "[[logo]]",
    "foundingDate": "[[founding_date]]",
